# Ignore build directories
/build/
/bin/
/obj/

# Ignore the IDE specific files (for Visual Studio, if using it)
.vs/
.vscode/
.idea/

# Ignore compiled binary files
*.exe
*.out
*.app

# Ignore temporary files created by the system or the editor
*.log
*.tmp
*.swp
*.bak

# Ignore dependency directories
/third_party/
extern/

# Ignore CMake or other build system files if using CMake
CMakeCache.txt
CMakeFiles/
Makefile
Makefile.in
*.cmake

# Ignore package manager files (e.g., for vcpkg, if used)
/vcpkg/

# Ignore generated files from IDEs
*.user
*.userprefs

# Ignore Mac OS system files
.DS_Store

# Ignore Linux system files
*~

# Ignore Windows system files
Thumbs.db


# Executables
*.exe
*.out
*.app
